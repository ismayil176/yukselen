# Required in production
APP_SESSION_SECRET=change-this-to-a-random-32-plus-char-secret
DATABASE_URL=postgresql://...
DATABASE_PUBLIC_URL=postgresql://...

# Admin login (set at least one strategy)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisPassword123!

# Optional: use hashed password instead of plain password
# ADMIN_PASSWORD_SALT=
# ADMIN_PASSWORD_HASH=

# Optional 2FA
# ADMIN_TOTP_ENABLED=true
# ADMIN_TOTP_SECRET=
# ADMIN_TOTP_ISSUER=Yukselis Exam
# ADMIN_TOTP_LABEL=admin

# Public site URL for sitemap/canonical metadata
NEXT_PUBLIC_SITE_URL=https://www.yukselen.az
